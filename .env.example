# Host + player role
HOST_USER_NAME=YofiAsi
HOST_STALE_SECONDS=30
PLAYER_STALE_SECONDS=20
SESSION_SECRET=change-me-long-random

# Note: DOMAIN / TLS are configured in the Dokploy UI, not here.

# Postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://karaoke:change-me@postgres:5432/karaoke

# MinIO
MINIO_ROOT_USER=karaoke
MINIO_ROOT_PASSWORD=change-me-long
MINIO_BUCKET=karaoke

# Worker / GPU
AUDIO_SEP_MODEL=UVR-MDX-NET-Inst_HQ_3.onnx
# openvino = Intel Arc (docker-compose.yml)
# cuda     = NVIDIA GPU (docker-compose.nvidia.yml)
# cpu      = fallback, no GPU
SEPARATOR_BACKEND=openvino
# Intel Arc only — override if host uses non-default GIDs for render/video:
# RENDER_GID=109
# VIDEO_GID=44

# Public origin the web app is served from.
# Baked into the web image at build time so the Socket.IO client connects
# same-origin through the public reverse proxy (Dokploy's Traefik, or the
# Caddy+ngrok stack in docker-compose.nvidia.yml).
# Leave blank for purely-local dev without a tunnel (Socket.IO falls back to
# <hostname>:4000, which only works if the api port is bound on the host).
# Example: https://karaoke.example.com
NEXT_PUBLIC_WS_URL=

# Restrict api CORS + Socket.IO origin to this value in prod.
# Empty = allow all (dev default).
# Example: https://karaoke.example.com
PUBLIC_ORIGIN=

# ngrok (docker-compose.nvidia.yml only): paid static/custom domain tunnel.
# NGROK_URL is the fully-qualified hostname pre-registered in the ngrok
# dashboard (CNAME'd from your registrar, e.g. Vercel DNS).
# NGROK_AUTHTOKEN comes from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_URL=karaoke.example.com
NGROK_AUTHTOKEN=
