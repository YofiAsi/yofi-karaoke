# Host + player role
HOST_USER_NAME=YofiAsi
HOST_STALE_SECONDS=30
PLAYER_STALE_SECONDS=20
SESSION_SECRET=change-me-long-random

# DOMAIN / TLS: configure only in the Dokploy UI for production, not in this file.

# Postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://karaoke:change-me@postgres:5432/karaoke

# MinIO
MINIO_ROOT_USER=karaoke
MINIO_ROOT_PASSWORD=change-me-long
MINIO_BUCKET=karaoke

# Worker / GPU
AUDIO_SEP_MODEL=UVR-MDX-NET-Inst_HQ_3.onnx
# openvino = Intel Arc (docker-compose.yml) — production stack
# cuda     = NVIDIA GPU (docker-compose.nvidia.yml) — dev/WSL alternative
# cpu      = fallback, no GPU
SEPARATOR_BACKEND=openvino
# Intel Arc only — override if host uses non-default GIDs for render/video:
# RENDER_GID=109
# VIDEO_GID=44

# --- Web Docker build (NEXT_PUBLIC_* is inlined at `pnpm build` / image build time)
# In Dokploy, set these as build arguments for the web service if you override defaults.
NEXT_PUBLIC_API_URL=/api
# same-origin = Socket.IO uses the browser origin (requires reverse proxy to forward
#   /socket.io to the api service on the same host, e.g. yofikaraoke.asafshilo.com).
# For local `pnpm --filter web dev` use: http://127.0.0.1:4000
# For a dedicated public API URL use a full URL, e.g. wss://yofikaraoke.asafshilo.com
NEXT_PUBLIC_WS_URL=same-origin
# Next server-side rewrites target (Docker service name)
API_INTERNAL_URL=http://api:4000
